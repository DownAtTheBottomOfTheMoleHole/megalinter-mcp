{
  "name": "@downatthebottomofthemolehole/megalinter-mcp-server",
  "version": "3.0.1",
  "mcpName": "io.github.DownAtTheBottomOfTheMoleHole/megalinter",
  "description": "MCP server for running Ox Security MegaLinter via mega-linter-runner",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "megalinter-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "mcp.json",
    "README.md",
    "LICENSE"
  ],
  "mcp": {
    "name": "megalinter-ox-security",
    "description": "Ox Security MegaLinter linting via MCP"
  },
  "keywords": [
    "mcp",
    "megalinter",
    "linting",
    "code-quality",
    "ox-security",
    "mega-linter-runner"
  ],
  "author": "Carl Dawson",
  "repository": "https://github.com/DownAtTheBottomOfTheMoleHole/megalinter-mcp",
  "homepage": "https://github.com/DownAtTheBottomOfTheMoleHole/megalinter-mcp",
  "bugs": {
    "url": "https://github.com/DownAtTheBottomOfTheMoleHole/megalinter-mcp/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "docs:links": "npx --yes markdown-link-check -c .markdown-link-check.json README.md docs/*.md"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "10.0.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "license": "MIT"
}
